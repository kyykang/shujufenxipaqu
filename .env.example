# 致远OA系统配置
# 复制此文件为 .env 并填入实际值

# OA系统登录地址
OA_URL=https://your-oa-system.com/seeyon/main.do?method=index

# 登录凭证（请妥善保管，不要提交到版本控制）
OA_USERNAME=your_username
OA_PASSWORD=your_password

# 请求延迟（秒），避免频繁访问
REQUEST_DELAY=2.0

# ========== 远程文件传输配置 ==========

# 传输方式: scp, rsync, sftp, http
TRANSFER_METHOD=scp

# SSH方式配置（scp/rsync/sftp）
REMOTE_HOST=192.168.1.100
REMOTE_USER=username
REMOTE_PATH=/path/to/destination
REMOTE_PORT=22

# SSH密钥路径（支持.pem格式，如AWS EC2密钥）
# 示例：
# SSH_KEY_PATH=/path/to/key.pem              # .pem格式（AWS等）
# SSH_KEY_PATH=/home/user/.ssh/id_rsa        # 标准SSH密钥
# SSH_KEY_PATH=~/.ssh/my-key.pem             # 支持~展开
SSH_KEY_PATH=/path/to/your-key.pem

# 如果不使用SSH密钥，可以使用密码（不推荐）
# REMOTE_PASSWORD=password

# HTTP方式配置
UPLOAD_URL=http://your-server.com/upload
UPLOAD_TOKEN=your_auth_token    # 可选，API认证token
